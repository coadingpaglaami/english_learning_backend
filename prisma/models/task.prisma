model Task {
  id            String @id @default(nanoid())
  title         String
  xpPerQuestion Int    @default(5) // NEW
  type            TaskType
  status          TaskStatus   @default(DRAFT)
  isPublic        Boolean      @default(false)
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  grammarContent  GrammarTask?
  questions       Question[]
  readingContent  ReadingTask?
  createdBy       User         @relation(fields: [createdById], references: [id])
  vocabularyItems WordItem[]
  classTasks      ClassTask[]
  attempts        Attempt[]
}

enum EntryType {
  ENTRY1
  ENTRY2
  ENTRY3
  LEVEL1
  LEVEL2
  LEVEL3
  LEVEL4
  LEVEL5
  LEVEL6
  LEVEL7
  LEVEL8
  LEVEL9
  LEVEL10
}

model ReadingTask {
  id           String        @id @default(nanoid())
  taskId       String        @unique
  content      String
  imageUrl     String?
  entryType    EntryType[]
  awardingBody AwardingBody?
  passLogic    PassLogicType @default(SCORE_ONLY)
  passMark     Int? // The minimum score required (if applicable)
  task         Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model GrammarTask {
  id        String      @id @default(nanoid())
  taskId    String      @unique
  content   String
  entryType EntryType[]
  task      Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model WordItem {
  id         String  @id @default(nanoid())
  taskId     String
  wordName   String
  definition String
  imageUrl   String?
  task       Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Question {
  id             String          @id @default(nanoid())
  taskId         String
  type           QuestionType
  order          Int             @default(0)
  config         Json
  createdAt      DateTime        @default(now())
  task           Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]
  criterion      Criterion?      @relation(fields: [criterionId], references: [id])
  criterionId    String?
}

enum TaskType {
  READING
  GRAMMAR
  VOCABULARY
}

enum TaskStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum QuestionType {
  MCQ
  GAP_FILL
  WORD_BOX_MATCH
  MATCHING
  QUESTION_ANSWER
}
